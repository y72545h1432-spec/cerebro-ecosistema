# ===== Claves de proveedores LLM GRATIS (runtime 'api', costo $0) =====
# Copia este archivo a  .env  y pega AL MENOS UNA clave. NUNCA subas tu .env real (ya esta en .gitignore).
# Con varias claves, el cliente LLM usa la 1a y, si falla o agota la cuota del dia, cae a la siguiente.
#
# Como cargar el .env en tu shell antes de usar los modelos gratis:
#   PowerShell:  Get-Content .env | ForEach-Object { if ($_ -match '^\s*([^#=]+)=(.*)$') { [Environment]::SetEnvironmentVariable($matches[1].Trim(), $matches[2].Trim()) } }
#   bash/zsh:    set -a; source .env; set +a

# --- Groq (rapido; ~1.000 req/dia gratis, sin tarjeta) ---  https://console.groq.com
GROQ_API_KEY=

# --- Google Gemini (1.500 req/dia gratis, sin tarjeta) ---  https://aistudio.google.com/apikey
GEMINI_API_KEY=
# (alternativa: GOOGLE_API_KEY tambien se reconoce)

# --- OpenRouter (modelos :free; 50 req/dia, 1.000 si cargas $10 una vez) ---  https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ===== Ajustes opcionales =====
# Orden de respaldo entre proveedores (default: groq,gemini,openrouter)
# CEREBRO_LLM_PROVIDERS=groq,gemini,openrouter
# Forzar un modelo concreto para TODOS los tiers (ignora el mapeo por tier)
# CEREBRO_LLM_MODEL=
# Proveedor CUSTOM: cualquier endpoint OpenAI-compatible (otro servicio, un gateway propio, etc.)
# CEREBRO_LLM_BASE_URL=
# CEREBRO_LLM_API_KEY=
